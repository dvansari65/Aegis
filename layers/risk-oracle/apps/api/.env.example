# risk-oracle-api
RISK_ORACLE_API_BIND=127.0.0.1:8080

# Optional: live monitor from Solana (both required to enable; otherwise `/v1/risk/*` stays demo)
# RISK_ORACLE_MONITOR_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# RISK_ORACLE_MONITOR_STATE_PUBKEY=<risk oracle state account base58>
# Optional circuit breaker account for “previous mode” in policy math
# RISK_ORACLE_MONITOR_CB_STATE_PUBKEY=<circuit breaker state account base58>
# RISK_ORACLE_MONITOR_ORACLE_CONFIDENCE=100
